{
    "extends": "../../../../../../tsconfig.base.json",
    "compilerOptions": {
        "strict": true,
        "target": "es2015",
        "lib": ["DOM", "ESNext"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "jsx": "react-jsx",
        "rootDir": ".",
        "types": ["react"]
    },
    "include": ["./**/*.ts", "./**/*.tsx"],
    "exclude": ["node_modules"]
}
