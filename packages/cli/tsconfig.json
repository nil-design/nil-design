{
    "extends": "../../tsconfig.build.json",

    "compilerOptions": {
        "composite": true,
        "rootDir": "./src",

        "target": "ESNext",
        "outDir": "./dist",
        "types": ["node", "jest"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
